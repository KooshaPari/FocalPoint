# Deliverfile for FocalPoint App Store delivery
# deliver manages App Store metadata and release notes

# Your bundle identifier
app_identifier "com.koosha.focalpoint"

# Your username (Apple ID)
username ENV["FASTLANE_APPLE_ID"] || "developer@example.com"

# Metadata language
metadata_language "en-US"

# Screenshots language
screenshots_language "en-US"

# Override system locale
override_language_dir_name "en-US"

# Automatically reject if there are analysis warnings
reject_if_possible true

# Submit for Review automatically (disabled for MVP; manual review workflow)
submit_for_review false

# Prerelease testing (TestFlight)
prerelease_version true

# Release notes source (read from file)
release_notes({
  default: File.read("fastlane/metadata/release_notes_latest.txt").strip
})

# Price tier (0 = free)
price_tier 0

# Folder containing metadata and screenshots
metadata_path "fastlane/metadata"

# Force skip screenshots upload (manual in MVP)
skip_screenshots true
