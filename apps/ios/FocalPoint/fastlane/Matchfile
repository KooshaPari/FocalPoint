# Matchfile for FocalPoint code signing
# match manages certificates and provisioning profiles

git_url ENV["MATCH_GIT_URL"] || "https://github.com/KooshaPari/focalpoint-codesigning.git"
git_branch ENV["MATCH_GIT_BRANCH"] || "main"
git_full_name ENV["MATCH_GIT_NAME"] || "FocalPoint CI"
git_user_email ENV["MATCH_GIT_EMAIL"] || "noreply@focalpoint.local"

# Code signing type: appstore for TestFlight + App Store
type ENV["MATCH_TYPE"] || "appstore"

# Team ID
team_id ENV["FASTLANE_TEAM_ID"] || "GCT2BN8WLL"

# Your app identifier
app_identifier ["com.koosha.focalpoint"]

# Force force_for_new_devices to ensure any new devices are added to provisioning profiles
force_for_new_devices true

# Readonly mode (prevents automatic updates during build)
readonly isCI

# Storage mode (github, gitlab, s3, google_cloud, azure_key_vault)
storage_mode "git"

# Verbose logging
verbose true
