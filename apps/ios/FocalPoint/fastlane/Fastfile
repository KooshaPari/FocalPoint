default_platform(:ios)

platform :ios do
  # Smoke lane: build for Mac Designed-for-iPad, runs xcodegen first if needed
  desc "Build FocalPoint for Mac (Designed for iPad) — dev loop"
  lane :smoke do
    # Regenerate Xcode project from project.yml if not present
    unless File.exist?("FocalPoint.xcodeproj")
      UI.message("📦 Generating Xcode project from project.yml...")
      sh("xcodegen generate")
    end

    UI.message("🔨 Building for Mac Designed-for-iPad...")
    build_app(
      workspace: "FocalPoint.xcworkspace",
      scheme: "FocalPointApp",
      destination: "generic/platform=macOS,variant=Designed for iPad",
      configuration: "Debug",
      derived_data_path: "build",
      skip_package_ipa: true,
      skip_package_pkg: true,
      destination_timeout: 300
    )

    UI.success("✅ Smoke build complete!")
  end

  # Snapshot testing lane: runs swift-snapshot-testing, records on first run
  desc "Run swift-snapshot-testing (records new snapshots on first run)"
  lane :snapshot do
    # Regenerate Xcode project if needed
    unless File.exist?("FocalPoint.xcodeproj")
      UI.message("📦 Generating Xcode project from project.yml...")
      sh("xcodegen generate")
    end

    UI.message("📸 Running snapshot tests...")

    # Snapshot tests run with record=true on first run (controlled via env var RECORD)
    record_flag = ENV["RECORD"] == "true" ? true : false

    build_app(
      workspace: "FocalPoint.xcworkspace",
      scheme: "FocalPointApp",
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator,name=iPhone 15 Pro",
      derived_data_path: "build",
      skip_package_ipa: true,
      skip_package_pkg: true,
      build_for_testing: true
    )

    sh("xcodebuild test -scheme FocalPointAppSnapshotTests -workspace FocalPoint.xcworkspace -configuration Debug -destination 'generic/platform=iOS Simulator,name=iPhone 15 Pro' #{record_flag ? "-recordSnapshots" : ""}")

    UI.success("✅ Snapshot tests complete!")
  end

  # Beta lane: build for iOS device, upload to TestFlight
  desc "Build for iOS and upload to TestFlight"
  lane :beta do
    # Entitlement check: fail loudly if FamilyControls entitlement not approved
    unless ENV["FAMILY_CONTROLS_ENTITLEMENT_APPROVED"] == "yes"
      UI.error("❌ CRITICAL: FamilyControls entitlement is NOT approved by Apple.")
      UI.error("   This app requires explicit entitlement approval before TestFlight upload.")
      UI.error("   Submit request at: https://developer.apple.com/contact/request/family-controls-distribution")
      UI.error("   Set FAMILY_CONTROLS_ENTITLEMENT_APPROVED=yes once approved.")
      UI.abort_with_message!("FamilyControls entitlement approval required. Blocking TestFlight upload.")
    end

    # Regenerate Xcode project if needed
    unless File.exist?("FocalPoint.xcodeproj")
      UI.message("📦 Generating Xcode project from project.yml...")
      sh("xcodegen generate")
    end

    UI.message("🚀 Building for TestFlight...")

    build_app(
      workspace: "FocalPoint.xcworkspace",
      scheme: "FocalPointApp",
      configuration: "Release",
      destination: "generic/platform=iOS",
      derived_data_path: "build",
      export_method: "app-store",
      export_team_id: "GCT2BN8WLL"
    )

    UI.message("📤 Uploading to TestFlight...")
    upload_to_testflight(
      api_key_path: "fastlane/AuthKey.json",
      ipa: "FocalPointApp.ipa"
    )

    # Read release notes from metadata file
    release_notes_file = "fastlane/metadata/release_notes_latest.txt"
    release_notes = File.exist?(release_notes_file) ? File.read(release_notes_file).strip : "See commit history"

    UI.message("📝 Release notes: #{release_notes[0...100]}...")
    UI.success("✅ TestFlight upload complete!")
  end

  # Screenshots lane: seed fixture DB, boot app, capture screenshots
  desc "Generate App Store screenshots: seed fixture DB, boot app on macOS iPad, capture 6 screens"
  lane :screenshots do
    UI.message("📸 App Store Screenshot Generation Pipeline")
    UI.message("=" * 50)

    # 1. Regenerate Xcode project if needed
    unless File.exist?("FocalPoint.xcodeproj")
      UI.message("📦 Generating Xcode project from project.yml...")
      sh("xcodegen generate")
    end

    # 2. Seed fixture DB via focus CLI (if available)
    UI.message("\n1️⃣  Seeding fixture database...")
    fixture_db_path = "fastlane/fixtures/focus_fixture.db"
    Dir.chdir("../../../..") do
      if system("command -v focus >/dev/null 2>&1")
        # focus CLI is available
        # Initialize fresh DB for screenshots (v0.0.1 scaffold uses demo seed)
        sh("focus db init --path #{fixture_db_path}") if !File.exist?(fixture_db_path)

        # Use new focus demo seed command for realistic fixture data
        if system("focus demo seed --help >/dev/null 2>&1")
          sh("focus demo seed --db #{fixture_db_path}")
          UI.message("   ✓ Seeded demo data (10 tasks, 5 rules, 85 credits, 3 connectors, audit trail)")
        else
          # Fallback: manual fixture if demo seed not yet implemented
          UI.message("   ⚠️  focus demo seed not available; using fallback fixture data")
          sh("focus task add --db #{fixture_db_path} --title 'Finish Q2 Roadmap' --duration 25")
          sh("focus task add --db #{fixture_db_path} --title 'Code review PRs' --duration 30")
          sh("focus task add --db #{fixture_db_path} --title 'Team standup prep' --duration 15")
          sh("focus task add --db #{fixture_db_path} --title 'Design system audit' --duration 45")
          sh("focus task add --db #{fixture_db_path} --title 'Deploy hotfix' --duration 20")
          UI.message("   ✓ Added 5 sample tasks")

          # Grant some credits
          sh("focus wallet credit --db #{fixture_db_path} --amount 250")
          UI.message("   ✓ Granted 250 credits")
        end
      else
        UI.important("⚠️  focus CLI not found in PATH. Skipping fixture seeding.")
        UI.important("   Install: cd crates/focus-cli && cargo install --path .")
      end
    end

    # 3. Build app for macOS Designed-for-iPad
    UI.message("\n2️⃣  Building FocalPoint for macOS iPad (snapshot destination)...")
    build_app(
      workspace: "FocalPoint.xcworkspace",
      scheme: "FocalPointApp",
      configuration: "Debug",
      destination: "generic/platform=macOS,variant=Designed for iPad",
      derived_data_path: "build",
      skip_package_ipa: true,
      skip_package_pkg: true,
      destination_timeout: 300
    )
    UI.message("   ✓ Build succeeded")

    # 4. Launch app with fixture DB (via environment variable or app argument)
    UI.message("\n3️⃣  Launching app with fixture database...")
    # Note: This is a placeholder; actual launch requires an integration test harness
    UI.important("   App launch with seeded DB requires integration test target (Phase 2)")
    UI.message("   See: docs/release/app_preview_video_spec.md for manual screenshot instructions")

    # 5. Capture screenshots (placeholder for Phase 2)
    UI.message("\n4️⃣  Screenshot capture...")
    screenshots_dir = "fastlane/screenshots/en-US"
    FileUtils.mkdir_p(screenshots_dir)

    # Placeholder: document expected screenshot names
    expected_screenshots = [
      "01-today-screen.png",
      "02-focus-session-active.png",
      "03-tasks-list.png",
      "04-rewards-shop.png",
      "05-stats-dashboard.png",
      "06-settings-screen.png"
    ]

    UI.message("   Expected screenshots (Phase 2):")
    expected_screenshots.each { |s| UI.message("     - #{s}") }

    # 5. Reset demo data (cleanup for next run)
    UI.message("\n5️⃣  Cleaning up demo data...")
    Dir.chdir("../../../..") do
      if system("command -v focus >/dev/null 2>&1")
        if system("focus demo reset --help >/dev/null 2>&1")
          sh("focus demo reset --db #{fixture_db_path}")
          UI.message("   ✓ Demo data reset")
        end
      end
    end

    # 6. Summary
    UI.message("\n" + "=" * 50)
    UI.success("✅ Screenshot generation pipeline ready!")
    UI.message("\n📝 Next steps:")
    UI.message("   1. Implement integration test harness (Phase 2)")
    UI.message("   2. Record actual app screenshots using fastlane snapshot tool")
    UI.message("   3. Verify all 6 screenshots in: fastlane/screenshots/en-US/")
    UI.message("   4. Run: fastlane deliver_screenshots")
  end

  # Deliver screenshots lane (gated on entitlement approval)
  desc "Upload App Store screenshots via deliver (gated on entitlement approval)"
  lane :deliver_screenshots do
    unless ENV["FAMILY_CONTROLS_ENTITLEMENT_APPROVED"] == "yes"
      UI.error("❌ CRITICAL: FamilyControls entitlement is NOT approved.")
      UI.error("   Cannot upload screenshots without entitlement approval.")
      UI.error("   Set FAMILY_CONTROLS_ENTITLEMENT_APPROVED=yes once approved.")
      UI.abort_with_message!("Entitlement approval required. Blocking screenshot upload.")
    end

    UI.message("📤 Uploading App Store screenshots...")
    deliver(
      app_identifier: "com.example.focalpoint",
      skip_binary_upload: true,
      skip_metadata: true,
      screenshots_path: "fastlane/screenshots"
    )
    UI.success("✅ Screenshots uploaded successfully!")
  end

  # Benchmark compile-check lane: verify all benches compile (no-run mode)
  desc "Compile all Criterion benchmarks (no actual runs — fast verification)"
  lane :bench do
    UI.message("🔬 Compiling Criterion benchmarks (no-run mode)...")

    Dir.chdir("../../../..") do
      sh("cargo bench --no-run --workspace")
    end

    UI.success("✅ All benchmarks compiled successfully!")
  end

  # Full benchmark lane: run real benchmarks and generate HTML reports
  desc "Run full Criterion benchmarks with HTML report generation"
  lane :bench_full do
    UI.message("🔬 Running Criterion benchmarks (full execution with reports)...")
    UI.important("⚠️  This will take 5+ minutes. Run in background if needed.")

    Dir.chdir("../../../..") do
      sh("cargo bench --workspace")
    end

    UI.message("📊 Criterion reports available at: target/criterion/")
    UI.success("✅ Benchmarks complete!")
  end

  # Integration testing lane: run end-to-end FFI tests
  desc "Run end-to-end integration tests (Rust↔Swift bridge via FFI)"
  lane :integration do
    # Regenerate Xcode project if needed
    unless File.exist?("FocalPoint.xcodeproj")
      UI.message("📦 Generating Xcode project from project.yml...")
      sh("xcodegen generate")
    end

    UI.message("🔗 Running integration tests (FFI + event pipeline)...")

    # Run FocalPointIntegrationTests target on Mac Designed-for-iPad (no simulator overhead).
    sh(
      "xcodebuild test " \
      "-scheme FocalPointApp " \
      "-workspace FocalPoint.xcworkspace " \
      "-configuration Debug " \
      "-destination 'generic/platform=macOS,variant=Designed for iPad' " \
      "-only-testing:FocalPointIntegrationTests"
    )

    UI.success("✅ Integration tests complete!")
  end

  # CI lane: full automation pipeline (Rust + Swift checks)
  desc "Full CI pipeline: cargo test, clippy, fmt, xcodebuild smoke/snapshot/integration"
  lane :ci do
    UI.message("🤖 FocalPoint CI Pipeline Starting...")

    # 1. Rust cargo test
    UI.message("1️⃣  Testing Rust crates...")
    Dir.chdir("../../../..") do
      sh("cargo test --workspace")
    end

    # 2. Clippy lint
    UI.message("2️⃣  Linting with clippy...")
    Dir.chdir("../../../..") do
      sh("cargo clippy --workspace --tests -- -D warnings")
    end

    # 3. Format check
    UI.message("3️⃣  Checking format...")
    Dir.chdir("../../../..") do
      sh("cargo fmt --check")
    end

    # 4. Xcodebuild smoke
    UI.message("4️⃣  Running xcodebuild smoke (Mac Designed-for-iPad)...")
    smoke

    # 5. Snapshot tests
    UI.message("5️⃣  Running snapshot tests...")
    snapshot

    # 6. Integration tests
    UI.message("6️⃣  Running integration tests...")
    integration

    UI.success("✅ All CI checks passed!")
  end
end
