# FocalPoint fastlane configuration
# Copy to .env.fastlane and populate with real values (secrets do NOT commit to repo)

# Apple Developer Account
FASTLANE_APPLE_ID=your-apple-id@example.com
FASTLANE_TEAM_ID=GCT2BN8WLL
FASTLANE_ITC_TEAM_ID=GCT2BN8WLL

# Code Signing (match)
# Git repo URL where certificates + provisioning profiles are stored
MATCH_GIT_URL=https://github.com/KooshaPari/focalpoint-codesigning.git
MATCH_GIT_BRANCH=main
MATCH_GIT_NAME=FocalPoint CI
MATCH_GIT_EMAIL=noreply@focalpoint.local

# Code signing type: appstore, adhoc, development, enterprise
MATCH_TYPE=appstore

# Xcode settings
FASTLANE_XCODE_VERSION=26.0

# App Store Connect API Key
# Download JSON from https://appstoreconnect.apple.com/access/integrations/api
# Point to the file path (do NOT commit to repo; use secure CI secret)
APP_STORE_CONNECT_API_KEY_PATH=fastlane/AuthKey.json

# TestFlight Beta Review information
BETA_BUILD_INFO_FEEDBACK_EMAIL=feedback@focalpoint.local
BETA_BUILD_INFO_CONTACT_EMAIL=support@focalpoint.local

# Release notes
RELEASE_NOTES_FILE=fastlane/metadata/release_notes_latest.txt

# Entitlement status
# Set to "yes" ONLY after FamilyControls entitlement is approved by Apple
FAMILY_CONTROLS_ENTITLEMENT_APPROVED=no

# Snapshot testing
# Set to "true" on first run to record new baselines; "false" for comparison
RECORD=false

# CI environment detection
# Set to "true" if running in GitHub Actions or other CI
CI=false
