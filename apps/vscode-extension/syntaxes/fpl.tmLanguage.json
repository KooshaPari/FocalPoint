{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FPL (FocalPoint Policy Language)",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#macros"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.fpl",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fpl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fpl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.fpl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.fpl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.fpl",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.fpl",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fpl",
          "match": "\\b(if|elif|else|for|while|in|and|or|not|is|None|True|False)\\b"
        },
        {
          "name": "keyword.fpl",
          "match": "\\b(rule|task|schedule|connector|scene|coaching|enforcement|wallet_op|morning_brief|evening_shutdown|sound_cue|audit_query)\\b"
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "support.function.macro.fpl",
          "match": "\\b(reward|penalize|remind|celebrate|block|unlock_after|track_streak|if_pattern)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.action.fpl",
          "match": "\\b(on_event|on_schedule|grant_credit|deduct_credit|notify|lock|unlock)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.condition.fpl",
          "match": "\\b(confidence_gte|payload_eq|time_in_range|after_count|on_streak|within_window)\\b(?=\\s*\\()"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.fpl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.fpl"
            }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.fpl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.fpl",
          "match": "(==|!=|<=|>=|<|>|=)"
        },
        {
          "name": "punctuation.separator.fpl",
          "match": "[,;:]"
        }
      ]
    }
  },
  "scopeName": "source.fpl"
}
