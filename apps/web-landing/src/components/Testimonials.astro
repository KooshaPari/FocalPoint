---
import type { TestimonialsSection } from '../types';
import copy from '../content/copy.json';

const section = copy.testimonials as TestimonialsSection;
---

<section class="py-20 sm:py-32 bg-gradient-to-b from-dark-800 to-dark-900">
  <div class="mx-auto max-w-4xl px-6 sm:px-8">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-4xl font-bold text-white sm:text-5xl">{section.title}</h2>
      <p class="text-gray-400 sm:text-lg">{section.subtitle}</p>
    </div>

    <!-- Placeholder for testimonials -->
    <div class="rounded-xl border border-gray-700 bg-gray-800/20 p-12 text-center">
      <svg class="mx-auto mb-4 h-12 w-12 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
      </svg>
      <p class="text-gray-400">{section.note}</p>
    </div>
  </div>
</section>
