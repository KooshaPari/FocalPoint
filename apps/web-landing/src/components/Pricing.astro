---
import type { PricingSection } from '../types';
import copy from '../content/copy.json';

const section = copy.pricing as PricingSection;
---

<section class="py-20 sm:py-32 bg-dark-900">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold text-white sm:text-5xl">{section.title}</h2>
      <p class="text-gray-400 sm:text-lg">{section.subtitle}</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {section.tiers.map((tier) => (
        <div class={`rounded-xl border p-8 transition-all ${
          tier.highlighted
            ? 'border-blue-500 bg-blue-500/10 shadow-lg shadow-blue-500/20 lg:scale-105'
            : 'border-gray-700 bg-gray-800/20'
        } hover:border-blue-500 hover:bg-blue-500/5`}>
          {tier.highlighted && (
            <div class="mb-4 inline-block rounded-full bg-blue-500 px-3 py-1 text-xs font-semibold text-white">
              Most Popular
            </div>
          )}

          <h3 class="mb-2 text-2xl font-bold text-white">{tier.name}</h3>
          <p class="mb-6 text-gray-400">{tier.description}</p>

          <!-- Price -->
          <div class="mb-6">
            <span class="text-4xl font-bold text-white">{tier.price}</span>
            <span class="text-gray-400 ml-2">{tier.billing}</span>
          </div>

          <!-- Features -->
          <ul class="mb-8 space-y-3">
            {tier.features.map((feature) => (
              <li class="flex items-start">
                <svg class="h-5 w-5 text-blue-400 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm text-gray-300">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <button class={`w-full rounded-lg py-3 font-semibold transition-all ${
            tier.highlighted
              ? 'bg-blue-600 text-white hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/50'
              : 'border border-gray-600 text-gray-100 hover:border-blue-500 hover:bg-blue-500/10'
          }`}>
            {tier.cta}
          </button>
        </div>
      ))}
    </div>
  </div>
</section>
