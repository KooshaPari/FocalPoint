---
import type { FeaturesSection } from '../types';
import copy from '../content/copy.json';

const features = copy.features as FeaturesSection;
---

<section class="py-20 sm:py-32 bg-dark-900">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <!-- Connectors -->
    <div class="mb-20">
      <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl">10+ Connectors</h2>
      <p class="mb-8 text-gray-400">Connect to the tools your team uses.</p>

      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5">
        {features.connectors.map((connector) => (
          <div class="rounded-lg border border-gray-700 bg-gray-800/30 px-4 py-6 text-center transition-all hover:border-blue-500 hover:bg-blue-500/5">
            <div class="mb-3 text-4xl">{connector.icon}</div>
            <p class="text-sm font-semibold text-gray-200">{connector.name}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Feature Grid -->
    <div>
      <h2 class="mb-12 text-3xl font-bold text-white sm:text-4xl">Built for Focus</h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {features.grid.map((item) => (
          <div class="rounded-xl border border-gray-700 bg-gray-800/20 p-8 transition-all hover:border-blue-500 hover:bg-blue-500/5 hover:shadow-lg">
            <h3 class="mb-3 text-xl font-semibold text-white">{item.title}</h3>
            <p class="text-gray-400">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
