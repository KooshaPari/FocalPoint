---
import type { HowItWorksSection } from '../types';
import copy from '../content/copy.json';

const section = copy.how_it_works as HowItWorksSection;
---

<section id="how-it-works" class="py-20 sm:py-32 bg-gradient-to-b from-dark-900 to-dark-800">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold text-white sm:text-5xl">{section.title}</h2>
      <p class="text-gray-400 sm:text-lg">{section.subtitle}</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-3">
      {section.steps.map((step, idx) => (
        <div class="relative">
          <!-- Step card -->
          <div class="rounded-xl border border-gray-700 bg-gray-800/30 p-8 text-center transition-all hover:border-blue-500 hover:bg-blue-500/5">
            <!-- Number badge -->
            <div class="mx-auto mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-2xl font-bold text-white">
              {step.number}
            </div>
            <h3 class="mb-3 text-xl font-semibold text-white">{step.title}</h3>
            <p class="text-gray-400">{step.description}</p>
          </div>

          <!-- Connector arrow (hidden on last item) -->
          {idx < section.steps.length - 1 && (
            <div class="hidden sm:block absolute top-1/2 -right-4 w-8 h-0.5 bg-gradient-to-r from-blue-500 to-transparent transform -translate-y-1/2"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
