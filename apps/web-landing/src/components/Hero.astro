---
import type { HeroSection } from '../types';
import copy from '../content/copy.json';

const hero = copy.hero as HeroSection;
---

<section class="relative overflow-hidden bg-gradient-to-b from-dark-900 to-dark-800 py-20 sm:py-32 lg:py-48">
  <!-- Decorative background element -->
  <div class="absolute inset-0 overflow-hidden">
    <svg class="absolute h-full w-full opacity-10" viewBox="0 0 1200 1200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="600" cy="600" r="800" stroke="currentColor" stroke-width="1" opacity="0.1"></circle>
      <circle cx="600" cy="600" r="600" stroke="currentColor" stroke-width="1" opacity="0.1"></circle>
      <circle cx="600" cy="600" r="400" stroke="currentColor" stroke-width="1" opacity="0.1"></circle>
    </svg>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 text-center sm:px-8">
    <!-- Coachy mascot placeholder -->
    <div class="mx-auto mb-12 h-32 w-32 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-6xl shadow-lg">
      🤖
    </div>

    <!-- Tagline badge -->
    <div class="mb-6 inline-block">
      <span class="rounded-full bg-blue-500/10 px-4 py-2 text-sm font-semibold text-blue-400 ring-1 ring-blue-500/20">
        Focus wins. Rewards follow.
      </span>
    </div>

    <!-- Headline -->
    <h1 class="mb-6 text-5xl font-bold leading-tight text-white sm:text-6xl lg:text-7xl">
      {hero.headline}
    </h1>

    <!-- Subheading -->
    <p class="mx-auto mb-12 max-w-2xl text-lg text-gray-400 sm:text-xl">
      {hero.subheading}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col gap-4 sm:flex-row justify-center">
      <a href={hero.cta_primary_url} class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-8 py-4 font-semibold text-white transition-all hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/50">
        {hero.cta_primary}
        <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <a href={hero.cta_secondary_url} class="inline-flex items-center justify-center rounded-lg border border-gray-600 px-8 py-4 font-semibold text-gray-100 transition-all hover:border-gray-500 hover:bg-gray-800/50">
        {hero.cta_secondary}
      </a>
    </div>
  </div>
</section>
