# FocalPoint Release Bot Configuration
# Do NOT commit the actual webhook URL to git.
# Load this at runtime in CI/scripts: source .env && focus release-notes ...

# Discord webhook URL for posting release notes to #releases
# Format: https://discord.com/api/webhooks/{id}/{token}
# Get this from: Discord server → #releases → Integrations → Webhooks → FocalPoint Release Bot
FOCALPOINT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID_HERE/YOUR_TOKEN_HERE

# Optional: Enable LLM-powered release notes synthesis
# When set, focus release-notes generator will call an LLM to summarize commit groups
# Requires API key for the LLM service (not yet implemented; for future use)
# FOCALPOINT_RELEASE_NOTES_LLM=true
