namespace focus_ffi {
};

// ---------------------------------------------------------------------------
// Errors
// ---------------------------------------------------------------------------

[Error]
enum FfiError {
    "NotImplemented",
    "InvalidArgument",
    "Storage",
    "Domain",
    "Config",
    "Network",
};

// ---------------------------------------------------------------------------
// Mascot (unchanged)
// ---------------------------------------------------------------------------

enum Pose {
    "Confident",
    "Encouraging",
    "CuriousThinking",
    "SternToughLove",
    "Celebratory",
    "SleepyDisappointed",
    "Idle",
};

enum Emotion {
    "Neutral",
    "Happy",
    "Proud",
    "Concerned",
    "Stern",
    "Excited",
    "Tired",
    "Warm",
};

dictionary MascotState {
    Pose pose;
    Emotion emotion;
    string since_iso;
    string? bubble_text;
};

[Enum]
interface MascotEvent {
    RuleFired(string rule_name);
    StreakIncremented(string name, u32 count);
    StreakReset(string name);
    CreditEarned(i64 amount);
    BypassSpent(i64 remaining);
    PenaltyEscalated(string tier);
    AppLaunchedWhileBlocked(string bundle_id);
    FocusSessionStarted(u32 minutes);
    FocusSessionCompleted(u32 minutes);
    DailyCheckIn();
    SleepDebtReported(f32 hours);
    Idle();
};

// ---------------------------------------------------------------------------
// Rules
// ---------------------------------------------------------------------------

dictionary RuleSummary {
    string id;
    string name;
    i32 priority;
    string explanation_template;
    boolean enabled;
};

[Enum]
interface RuleActionDto {
    GrantCredit(i32 amount);
    DeductCredit(i32 amount);
    Block(string profile, i64 duration_seconds);
    Unblock(string profile);
    StreakIncrement(string name);
    StreakReset(string name);
    Notify(string message);
};

dictionary RuleDraft {
    string id;
    string name;
    string trigger_event;
    sequence<RuleActionDto> actions;
    i32 priority;
    i64? cooldown_seconds;
    i64? duration_seconds;
    string explanation_template;
    boolean enabled;
};

interface RuleQuery {
    [Throws=FfiError]
    sequence<RuleSummary> list_enabled();
};

interface RuleMutation {
    [Throws=FfiError]
    void set_enabled(string rule_id, boolean enabled);
    [Throws=FfiError]
    void upsert(RuleDraft rule);
};

// ---------------------------------------------------------------------------
// Rewards
// ---------------------------------------------------------------------------

dictionary StreakSummary {
    string name;
    u32 count;
    string? last_incremented_iso;
};

dictionary WalletSummary {
    i64 earned;
    i64 spent;
    i64 balance;
    f32 multiplier;
    sequence<StreakSummary> streaks;
};

[Enum]
interface WalletMutationDto {
    GrantCredit(i64 amount);
    SpendCredit(i64 amount, string purpose);
    StreakIncrement(string name);
    StreakReset(string name);
    SetMultiplier(f32 current, string? expires_iso);
};

interface WalletApi {
    [Throws=FfiError]
    WalletSummary load();
    [Throws=FfiError]
    void apply_mutation(WalletMutationDto m);
};

// ---------------------------------------------------------------------------
// Penalties
// ---------------------------------------------------------------------------

dictionary LockoutWindowDto {
    string starts_at_iso;
    string ends_at_iso;
    string reason;
};

dictionary PenaltyStateSummary {
    string tier;
    i64 bypass_budget;
    i64 debt_balance;
    string? strict_mode_until_iso;
    sequence<LockoutWindowDto> lockouts;
};

dictionary BypassQuoteDto {
    i64 cost;
    i64 remaining_after;
    string? new_tier;
};

[Enum]
interface PenaltyMutationDto {
    Escalate(string tier);
    SpendBypass(i64 amount);
    GrantBypass(i64 amount);
    AddLockout(LockoutWindowDto window);
    ClearLockouts();
    SetStrictMode(string until_iso);
    Clear();
};

interface PenaltyApi {
    [Throws=FfiError]
    PenaltyStateSummary load();
    [Throws=FfiError]
    BypassQuoteDto quote_bypass(i64 cost);
    [Throws=FfiError]
    void apply(PenaltyMutationDto m);
};

// ---------------------------------------------------------------------------
// Enforcement policy
// ---------------------------------------------------------------------------

dictionary EnforcementPolicySummary {
    boolean active;
    record<string, string> profile_states;
    string generated_at_iso;
};

interface PolicyApi {
    [Throws=FfiError]
    EnforcementPolicySummary build_from_recent_decisions(i32 limit);
};

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

interface AuditApi {
    [Throws=FfiError]
    boolean verify_chain();
    [Throws=FfiError]
    string? head_hash();
};

// ---------------------------------------------------------------------------
// Sync orchestrator
// ---------------------------------------------------------------------------

dictionary ConnectorHandleSummary {
    string connector_id;
    string health;
    string next_sync_at_iso;
    string? last_cursor;
};

dictionary SyncReportDto {
    u32 events_pulled;
    u32 connectors_synced;
    sequence<string> errors;
};

interface SyncApi {
    sequence<ConnectorHandleSummary> connectors();
    SyncReportDto tick();
};

// ---------------------------------------------------------------------------
// Coaching (LLM-backed bubble + rule authoring)
// ---------------------------------------------------------------------------

interface CoachingConfig {
    constructor(string endpoint, string api_key, string model);
};

// ---------------------------------------------------------------------------
// Rituals (Planning Coach — Morning Brief / Evening Shutdown)
// ---------------------------------------------------------------------------

dictionary TopPriorityLineDto {
    string task_id;
    string title;
    string deadline_label;
    string rigidity_tag;
    u32 estimated_duration_minutes;
};

dictionary ScheduleWindowLineDto {
    string starts_at_iso;
    string ends_at_iso;
    string title;
    string kind;
};

dictionary SchedulePreviewDto {
    sequence<ScheduleWindowLineDto> windows;
    u32 soft_conflicts;
    u32 hard_conflicts;
};

dictionary MorningBriefDto {
    string date;
    string? intention;
    sequence<TopPriorityLineDto> top_priorities;
    SchedulePreviewDto schedule_preview;
    string coachy_opening;
    string generated_at_iso;
};

dictionary ShippedTaskDto {
    string id;
    string title;
    u32 planned_minutes;
    u32 actual_minutes;
};

dictionary SlippedTaskDto {
    string id;
    string title;
    u32 planned_minutes;
    string reason;
};

dictionary EveningShutdownDto {
    string date;
    sequence<ShippedTaskDto> shipped;
    sequence<SlippedTaskDto> slipped;
    sequence<string> carryover;
    string wins_summary;
    string coachy_closing;
    record<string, i32> streak_deltas;
    string generated_at_iso;
};

dictionary TaskActualDto {
    string task_id;
    u32 actual_minutes;
    string? completed_at_iso;
    boolean cancelled;
};

interface RitualsApi {
    [Throws=FfiError]
    MorningBriefDto generate_morning_brief();
    [Throws=FfiError]
    EveningShutdownDto generate_evening_shutdown(sequence<TaskActualDto> actuals);
};

// ---------------------------------------------------------------------------
// Connectors
// ---------------------------------------------------------------------------

interface ConnectorApi {
    [Throws=FfiError]
    void connect_canvas(string instance_url, string code);
};

// ---------------------------------------------------------------------------
// Top-level core handle
// ---------------------------------------------------------------------------

interface FocalPointCore {
    [Throws=FfiError]
    constructor(string storage_path);

    // Mascot (unchanged).
    MascotState push_mascot_event(MascotEvent event);
    MascotState mascot_state();
    string app_version();

    // Coaching wiring.
    void set_coaching(CoachingConfig? config);
    string? generate_bubble(MascotEvent event);
    [Throws=FfiError]
    RuleSummary propose_rule_from_nl(string nl_spec);

    // Sub-API accessors.
    RuleQuery rules();
    RuleMutation mutations();
    WalletApi wallet();
    PenaltyApi penalty();
    PolicyApi policy();
    AuditApi audit();
    SyncApi sync();
    RitualsApi rituals();
    ConnectorApi connector();
};
