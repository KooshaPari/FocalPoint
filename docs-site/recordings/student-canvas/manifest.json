{
  "id": "student-canvas-onboarding",
  "title": "Student Canvas Onboarding",
  "persona": "Alice (CS Major, 4 Courses)",
  "platform": "ios",
  "duration_seconds": 120,
  "recording_date": "2026-04-30",
  "status": "pending_verification",
  "repository_path": "apps/ios/FocalPointUITests/journeys/student-canvas",
  "intent": {
    "summary": "Student downloads FocalPoint, links Canvas LMS, and creates first focus rule for assignment deadlines",
    "steps": [
      {
        "index": 1,
        "slug": "install-grant-permissions",
        "intent": "Download and install FocalPoint, grant FamilyControls entitlement",
        "precondition": "Fresh install, no accounts linked, App Store download",
        "expected_visible_change": "Permission dialog appears, user taps Allow"
      },
      {
        "index": 2,
        "slug": "view-morning-brief-empty",
        "intent": "See morning brief with empty state (no connectors yet)",
        "precondition": "Post-installation onboarding complete",
        "expected_visible_change": "Morning brief shows empty state with 'Connect your first app' CTA"
      },
      {
        "index": 3,
        "slug": "navigate-to-connectors",
        "intent": "Navigate to Settings > Connectors",
        "precondition": "Home screen visible",
        "expected_visible_change": "Settings list with Connectors option highlighted"
      },
      {
        "index": 4,
        "slug": "select-canvas-connector",
        "intent": "Find and select Canvas LMS connector",
        "precondition": "Connectors list visible",
        "expected_visible_change": "Canvas connector card with 'Install' button"
      },
      {
        "index": 5,
        "slug": "oauth-canvas-sso",
        "intent": "Authenticate via university SSO",
        "precondition": "Canvas install tapped, OAuth flow initiates",
        "expected_visible_change": "WebView with Canvas login, university SSO redirect"
      },
      {
        "index": 6,
        "slug": "select-courses",
        "intent": "Select 4 courses to sync",
        "precondition": "OAuth successful, course list returned",
        "expected_visible_change": "Multi-select list of courses with checkboxes"
      },
      {
        "index": 7,
        "slug": "verify-sync-complete",
        "intent": "Confirm sync complete, assignments appear",
        "precondition": "Courses selected, sync initiated",
        "expected_visible_change": "Sync spinner, then assignment list populates"
      },
      {
        "index": 8,
        "slug": "view-morning-brief-with-data",
        "intent": "See morning brief with Canvas assignments",
        "precondition": "Sync complete, returning to home",
        "expected_visible_change": "Morning brief shows assignments: 'CS 101 HW3 due Wed, MATH PS5 due Fri'"
      },
      {
        "index": 9,
        "slug": "create-first-rule",
        "intent": "Create rule: assignment due in 24h triggers focus mode",
        "precondition": "Rules screen, empty state",
        "expected_visible_change": "Rule editor with trigger block (canvas.assignment.due_soon) and action blocks"
      },
      {
        "index": 10,
        "slug": "test-rule-blocking",
        "intent": "Manually trigger rule to verify TikTok gets blocked",
        "precondition": "Rule saved, TikTok installed",
        "expected_visible_change": "Focus mode activates, TikTok grayed out, coach message shown"
      }
    ]
  },
