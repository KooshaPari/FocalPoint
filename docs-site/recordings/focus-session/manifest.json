  "intent": {
    "summary": "Developer starts a PR review focus session, gets interrupted, takes a break suggestion, and completes the review",
    "steps": [
      {
        "index": 1,
        "slug": "pr-notification-arrives",
        "intent": "GitHub PR notification triggers focus suggestion",
        "precondition": "Focus mode off, GitHub connected",
        "expected_visible_change": "Push notification: 'PR from @colleague: Add async pooling'"
      },
      {
        "index": 2,
        "slug": "tap-start-review",
        "intent": "Tap 'Start Review' from notification",
        "precondition": "Notification visible",
        "expected_visible_change": "Focus mode activates, Slack/Discord muted, GitHub opens in focus view"
      },
      {
        "index": 3,
        "slug": "focus-in-progress",
        "intent": "Review PR with focus mode active",
        "precondition": "Focus mode on",
        "expected_visible_change": "Timer counting up, blocked apps grayed, GitHub in foreground"
      },
      {
        "index": 4,
        "slug": "coachy-break-suggestion",
        "intent": "Coachy suggests break after 90 minutes",
        "precondition": "90 min elapsed",
        "expected_visible_change": "Coachy card: 'You've been focused for 90 min. Take a break?'"
      },
      {
        "index": 5,
        "slug": "take-break",
        "intent": "Tap 'Take 15 min break'",
        "precondition": "Break suggestion visible",
        "expected_visible_change": "Focus pauses, timer shows 15:00 countdown"
      },
      {
        "index": 6,
        "slug": "return-from-break",
        "intent": "Resume focus after break",
        "precondition": "15 min passed",
        "expected_visible_change": "Timer resumes, 'Ready to continue?' prompt"
      },
      {
        "index": 7,
        "slug": "complete-review",
        "intent": "Finish PR review, submit feedback",
        "precondition": "Review complete in GitHub",
        "expected_visible_change": "Focus ends, Coachy celebrates with stats"
      }
    ]
  },
