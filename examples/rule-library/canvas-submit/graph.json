{
  "version": 1,
  "kind": "Rule",
  "id": "canvas-submit",
  "name": "Canvas Assignment Submitted",
  "body": {
    "kind": "Rule",
    "id": "canvas-submit",
    "name": "Canvas Assignment Submitted",
    "trigger": {
      "type": "EventFired",
      "value": {
        "event_name": "canvas:assignment_submitted"
      }
    },
    "conditions": [],
    "actions": [
      {
        "type": "apply_mutation",
        "mutation_id": "grant_credits",
        "params": {
          "amount": 20
        }
      },
      {
        "type": "apply_mutation",
        "mutation_id": "increment_streak",
        "params": {
          "streak_name": "assignments"
        }
      }
    ],
    "priority": 50,
    "cooldown_seconds": null,
    "duration_seconds": null,
    "explanation_template": "Canvas assignment submitted: +20 credits + streak",
    "enabled": true
  }
}
