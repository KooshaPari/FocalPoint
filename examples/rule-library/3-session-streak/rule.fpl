rule(
    id="3-session-streak",
    name="3-Session Streak Celebration",
    trigger=on_state_change("session_streak"),
    conditions=[payload_eq(path="session_streak", value=3)],
    actions=[
        notify(message="Congratulations on 3 consecutive sessions!"),
        grant_credit(amount=10)
    ],
    priority=70
)
