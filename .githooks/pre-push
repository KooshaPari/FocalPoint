#!/bin/bash
# Pre-push hook: run quick quality gate before allowing push.
# This ensures only code that passes fmt + clippy reaches the remote.

set -e

# Build and run the quality-gate binary in quick mode
cd "$(git rev-parse --show-toplevel)"

# Build the binary if not present
if [ ! -f tooling/quality-gate/target/release/quality-gate ]; then
    echo "Building quality-gate binary..."
    cargo build --manifest-path tooling/quality-gate/Cargo.toml --release >/dev/null 2>&1
fi

# Run quick quality gate (fmt + clippy only)
echo "Running pre-push quality gate..."
./tooling/quality-gate/target/release/quality-gate --quick

if [ $? -ne 0 ]; then
    echo "❌ Pre-push quality gate failed. Fix issues above and retry."
    exit 1
fi

echo "✅ Pre-push quality gate passed."
exit 0
